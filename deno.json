{
  "name": "explicitjs",
  "version": "1.0.0",
  "exports": "./src/cli.ts",
  "tasks": {
    "start": "deno run --allow-read --allow-env src/cli.ts",
    "test": "deno test --allow-read --allow-env",
    "check": "deno check src/cli.ts test/checks.test.ts"
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "exclude": ["*.md"]
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}

{
  "name": "explicit-ts",
  "version": "1.0.0",
  "description": "A semantic clarity enforcer for production JavaScript/TypeScript — flags code where the author's intent is ambiguous.",
  "keywords": [
    "lint",
    "linter",
    "static-analysis",
    "typescript",
    "javascript",
    "explicit",
    "code-quality"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "explicit-ts": "dist/cli.js",
    "explicit": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "prepare": "npm run build",
    "test": "tsc -p tsconfig.test.json && tsc-alias -p tsconfig.test.json && node --test \"dist-test/test/**/*.test.js\"",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsc-alias": "^1.8.17"
  }
}
